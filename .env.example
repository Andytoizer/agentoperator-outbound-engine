# ============================================================
# Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ── People search (primary) ──────────────────────────────────
# AI Ark: B2B data platform for people + company search
# Get key: https://docs.ai-ark.com (sign up → developer portal → API keys)
AI_ARK_API_KEY=

# ── Email enrichment waterfall ───────────────────────────────
# Rung 1: Lead Magic (LinkedIn URL → email, best accuracy)
# Get key: https://leadmagic.io → dashboard → API keys
LEADMAGIC_API_KEY=

# Rung 2: Findymail (fallback)
# Get key: https://findymail.com → settings → API
FINDYMAIL_API_KEY=

# ── People search (optional secondary) ───────────────────────
# Apollo: typically driven through Claude Code MCP tool, so this is optional
# Get key: https://apollo.io → settings → integrations → API
APOLLO_API_KEY=

# ── Slack (for send reminders) ───────────────────────────────
# Your own user ID for DMs-to-self. Look it up in Claude via the
# Slack MCP tool — its description prints your user ID.
SLACK_USER_ID=

# Optional: channel ID for campaign logs (if you want a visible log alongside DMs)
SLACK_CHANNEL_ID=

# ── Gmail ────────────────────────────────────────────────────
# Typically driven via Claude Code Gmail MCP tool. Leave empty unless
# you're wiring up a direct google-auth-oauthlib flow.
GMAIL_SENDER=

# ── Research sub-agents (optional, for standalone Python runs) ─
# Only needed if you're running research without Claude Code driving it.
ANTHROPIC_API_KEY=

# ── Send scheduler tuning ────────────────────────────────────
SEND_TIMEZONE=America/Los_Angeles
SEND_WINDOW_START_HOUR=9
SEND_WINDOW_END_HOUR=12
SEND_PER_DAY_CAP=10
SEND_MIN_GAP_MIN=11
SEND_MAX_GAP_MIN=18
LI_DELAY_HOURS=24
